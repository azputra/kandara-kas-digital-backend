NODE_ENV=development
PORT=4000

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/kandara_kas_digital

# Auth
JWT_SECRET=ganti-dengan-string-panjang-acak

# Midtrans (Sandbox) — isi dari Dashboard > Settings > Access Keys
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# App URL (untuk CORS / dokumentasi)
PUBLIC_APP_URL=http://localhost:4000

# Seed (opsional): npm run seed — password default jika tidak di-set
# SEED_DEFAULT_PASSWORD=KandaraDev123!
